{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://director.local/schemas/research-dossier/v1",
  "title": "Research dossier body",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_id",
    "summary",
    "timeline",
    "sources_min_met",
    "disputed_claims_flagged"
  ],
  "properties": {
    "schema_id": { "type": "string", "const": "research-dossier/v1" },
    "summary": { "type": "string", "minLength": 1 },
    "timeline": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["label"],
        "additionalProperties": true,
        "properties": {
          "label": { "type": "string", "minLength": 1 },
          "notes": { "type": "string" },
          "approx_year": {
            "description": "Single calendar year (integer), unknown (null), or approximate era as text (e.g. decade string).",
            "type": ["integer", "string", "null"]
          }
        }
      }
    },
    "sources_min_met": { "type": "boolean" },
    "disputed_claims_flagged": { "type": "boolean" },
    "fact_graph": {
      "type": "object",
      "additionalProperties": true,
      "description": "Optional nodes/edges summary from Research Agent"
    },
    "chapter_evidence_packs": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true },
      "description": "Optional per-chapter evidence pointers"
    }
  }
}
