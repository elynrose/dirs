{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://director.local/schemas/director-pack/v1",
  "title": "Directely pack",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_id", "title", "topic", "narrative_arc", "style_notes", "production_constraints"],
  "properties": {
    "schema_id": { "type": "string", "const": "director-pack/v1" },
    "title": { "type": "string", "minLength": 1 },
    "topic": { "type": "string", "minLength": 1 },
    "narrative_arc": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "style_notes": { "type": "object", "additionalProperties": true },
    "production_constraints": { "type": "object", "additionalProperties": true }
  }
}
