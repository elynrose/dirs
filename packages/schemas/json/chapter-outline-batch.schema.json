{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://director.local/schemas/chapter-outline-batch/v1",
  "title": "Chapter outline batch",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_id", "chapters"],
  "properties": {
    "schema_id": { "type": "string", "const": "chapter-outline-batch/v1" },
    "chapters": {
      "type": "array",
      "minItems": 1,
      "maxItems": 24,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["order_index", "title", "summary", "target_duration_sec"],
        "properties": {
          "order_index": { "type": "integer", "minimum": 0 },
          "title": { "type": "string", "minLength": 1, "maxLength": 500 },
          "summary": { "type": "string", "minLength": 1, "maxLength": 8000 },
          "target_duration_sec": { "type": "integer", "minimum": 30, "maximum": 7200 }
        }
      }
    }
  }
}
