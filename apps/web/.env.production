# Production bundle: leave API base empty so the browser uses same-origin `/v1/...` (nginx → FastAPI).
# Never set loopback here — it gets baked into the JS and every visitor's browser would call *their* 127.0.0.1.
# If the UI and API are truly on different public origins, use e.g. VITE_API_BASE_URL=https://api.example.com
# and set CORS_EXTRA_ORIGINS on the API.
VITE_API_BASE_URL=
