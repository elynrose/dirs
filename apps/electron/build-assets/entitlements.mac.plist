<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <!-- Allow spawning child processes (Python API, Celery, Docker CLI) -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <!-- Allow loading unsigned dynamic libraries (Python extensions, numpy, torch) -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <!-- Outbound network (API calls to FAL, OpenAI, Gemini, etc.) -->
    <key>com.apple.security.network.client</key>
    <true/>
    <!-- Inbound connections (local API server on 127.0.0.1:8000) -->
    <key>com.apple.security.network.server</key>
    <true/>
    <!-- File access for user-selected storage locations -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
    <!-- Read-only access to home dir for locating Python / Homebrew -->
    <key>com.apple.security.files.all</key>
    <true/>
  </dict>
</plist>
