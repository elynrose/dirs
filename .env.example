# Copy to .env — never commit real secrets.

# PostgreSQL (docker-compose)
POSTGRES_USER=director
POSTGRES_PASSWORD=director_dev_change_me
POSTGRES_DB=director
DATABASE_URL=postgresql+psycopg://director:director_dev_change_me@localhost:5433/director

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery / agent runs
# If you start only the API (no worker), agent runs stay "queued" forever unless you use eager mode:
# CELERY_EAGER=true
# Eager runs tasks inside the API process (no separate worker window). Fine for local dev; do not use in production.
# On Windows, either set CELERY_EAGER=true, or start a worker (see scripts/launch-director.ps1 or scripts/restart-local.ps1).

# Asset storage (local-first)
# Default: filesystem under this directory (no cloud required)
# Default in code: <repo>/data/storage — override if needed
LOCAL_STORAGE_ROOT=
# STORAGE_BACKEND=filesystem | minio | s3
STORAGE_BACKEND=filesystem

# MinIO (optional — only if STORAGE_BACKEND=minio or for S3-shaped testing)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_change_me
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=director-assets
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin_change_me
S3_REGION=us-east-1

# API
API_HOST=0.0.0.0
API_PORT=8000
# Uvicorn auto-reload (dev). Default in cli is off unless API_RELOAD=1 is set in the **process environment**
# (the restart script does not load .env into the shell—use setx / machine env, or export before `python -m director_api`).
# API_RELOAD=1
LOG_LEVEL=INFO
# Rate limit (per client IP + tenant). Studio dev via Vite proxy can exceed 120/min; loopback is exempt by default.
# RATE_LIMIT_ENABLED=true
# API_RATE_LIMIT_PER_MINUTE=1000
# Set false if the API is only reached over loopback and you want RPM enforced anyway.
# RATE_LIMIT_RELAX_LOOPBACK=true
# Optional: extra CORS origins (comma-separated) if the web UI runs on another host/port
# (required for <video> / media if you set VITE_API_BASE_URL to this API — e.g. Studio on a VPS:)
# CORS_EXTRA_ORIGINS=http://localhost:3000,http://YOUR_VPS:5173,https://directely.com,https://www.directely.com

# Multi-tenant SaaS (optional). Default: off — Studio uses DEFAULT_TENANT_ID only (legacy local mode).
# DIRECTOR_AUTH_ENABLED=false
# DIRECTOR_JWT_SECRET=change-me-to-a-long-random-string
# DIRECTOR_JWT_EXPIRE_HOURS=168
# DIRECTOR_ALLOW_REGISTRATION=true
#
# Firebase / Google sign-in (optional). Web SDK config is returned by GET /v1/auth/config when these four are set.
# Token verification also requires a service account JSON file on the API host.
# DIRECTOR_FIREBASE_PROJECT_ID=director-xxxxx
# DIRECTOR_FIREBASE_WEB_API_KEY=AIza...
# DIRECTOR_FIREBASE_WEB_AUTH_DOMAIN=director-xxxxx.firebaseapp.com
# DIRECTOR_FIREBASE_WEB_APP_ID=1:123456:web:abcdef
# DIRECTOR_FIREBASE_CREDENTIALS_PATH=/absolute/path/to/firebase-adminsdk-xxxxx.json
#
# If the API does not expose firebase config yet, you can still show the Google button from the Vite app by setting
# the same values in apps/web/.env.development as VITE_FIREBASE_* (see apps/web/.env.example).
#
# When auth is enabled, GET /v1/metrics and POST /v1/celery/restart require header X-Director-Ops-Key matching:
# DIRECTOR_OPS_API_KEY=
# DIRECTOR_EXPOSE_OPENAPI=true
#
# Optional: workspace UUID whose Studio-saved API keys are inherited when either (a) the user has
# "Use platform API credentials" in Admin → Users, or (b) the workspace plan entitlement `platform_api_credentials`
# is true (Admin → Plans / billing override). Merged keys are never returned in GET /v1/settings — only server-side.
# Empty = disabled.
# DIRECTOR_PLATFORM_CREDENTIALS_SOURCE_TENANT_ID=

# Pydantic loads `.env` from the **repository root** (the folder that contains `apps/`), then `apps/api/.env`, then cwd.
# Job cap numbers are reported in GET /v1/metrics; enqueue is not blocked by caps (Studio runs many jobs in parallel).
# JOB_CAPS_ENFORCED=false
# JOB_CAP_MEDIA=8
# JOB_CAP_MEDIA_GLOBAL=20
# JOB_CAP_TEXT=5
# JOB_CAP_COMPILE=2

# Timeline / export — minimum hold after spoken scene VO before the next beat (seconds). Overridable in Studio → Settings → Automation.
# SCENE_VO_TAIL_PADDING_SEC=5

# Providers
# Budget / integration test: forces cheap placeholder images for image jobs (not cloud TTS — narration uses workspace speech settings).
# See scripts/budget_pipeline_test.py. Prefer setting preferred_* on the project only.
# DIRECTOR_PLACEHOLDER_MEDIA=false
# OPENAI_API_KEY=          # required for OpenAI cloud; also used for OpenAI TTS/images. Optional as fallback for LM Studio chat.
# OPENAI_API_BASE_URL=     # optional; Azure OpenAI or other OpenAI-compatible *cloud* endpoint (not LM Studio). /v1 is added automatically.
# OPENAI_COMPATIBLE_TEXT_SOURCE=openai   # optional; openai | lm_studio — which host receives OpenAI SDK *chat* (Studio: API keys tab).
# LM_STUDIO_API_BASE_URL=  # optional; local LM Studio, e.g. http://127.0.0.1:1234 (use with OPENAI_COMPATIBLE_TEXT_SOURCE=lm_studio)
# LM_STUDIO_API_KEY=       # optional; usually empty (SDK may use a placeholder)
# LM_STUDIO_TEXT_MODEL=    # optional; loaded model id in LM Studio; empty = reuse OPENAI_TEXT_MODEL
# OPENAI_LOCAL_CHAT_MAX_TOKENS=16384   # optional; completion budget for local OpenAI-compatible chat (Qwen3 / long JSON)
# OPENAI_TEXT_MODEL=gpt-4o-mini   # optional; same as OPENAI_SMOKE_MODEL (Studio “OpenAI text model” for cloud/Azure)
# OPENAI_TEXT_MODEL=qwen3-32b     # example: use as LM fallback when LM_STUDIO_TEXT_MODEL is empty
# OPENAI_TEXT_MODEL=gemma-3-4b-it  # example small local model id (match LM Studio’s list if used as fallback)
# OPENAI_TTS_MODEL=tts-1   # optional; e.g. tts-1-hd
# TAVILY_API_KEY=          # optional; web research uses Tavily when set, otherwise Wikipedia OpenSearch (no key)
# FAL_KEY=
# OPENROUTER_API_KEY=
# OPENROUTER_SMOKE_MODEL=openai/gpt-4o-mini
# XAI_API_KEY=
# GROK_API_KEY=
# XAI_TEXT_MODEL=grok-2-latest
# Google Gemini API (AI Studio key — text via Gemini, images via Imagen, video via Veo when enabled on your account)
# GEMINI_API_KEY=
# GEMINI_TEXT_MODEL=gemini-2.0-flash
# GEMINI_IMAGE_MODEL=imagen-4.0-generate-001
# GEMINI_VIDEO_MODEL=veo-3.1-generate-preview
# GROK_IMAGE_MODEL=grok-2-image
# GROK_VIDEO_MODEL=grok-2-video
# OPENAI_IMAGE_MODEL=gpt-image-1
# FAL_SMOKE_MODEL=fal-ai/fast-sdxl
# FAL_VIDEO_MODEL=fal-ai/minimax/video-01-live

# ComfyUI — workflow execution (export API-format JSON from the ComfyUI app).
# OSS (default): self-hosted ComfyUI — COMFYUI_BASE_URL=http://127.0.0.1:8188, optional COMFYUI_API_KEY as Bearer.
# Cloud: Comfy Cloud — https://docs.comfy.org/development/cloud/api-reference (subscription; experimental API)
# COMFYUI_API_FLAVOR=cloud
# COMFYUI_BASE_URL=   # optional for cloud; defaults to https://cloud.comfy.org
# COMFYUI_API_KEY=    # cloud: required as X-API-Key (same as COMFY_CLOUD_API_KEY). OSS: optional Bearer for proxies.
# COMFYUI_WORKFLOW_JSON_PATH=data/comfyui_workflows/still_api.json
# COMFYUI_VIDEO_WORKFLOW_JSON_PATH=data/comfyui_workflows/video_api.json   # ACTIVE_VIDEO_PROVIDER=comfyui_wan
# COMFYUI_TIMEOUT_SEC=900
# COMFYUI_VIDEO_TIMEOUT_SEC=1800
# COMFYUI_POLL_INTERVAL_SEC=1
# COMFYUI_VIDEO_LOAD_IMAGE_NODE_ID=
# COMFYUI_VIDEO_USE_SCENE_IMAGE=true
# Optional: COMFYUI_PROMPT_NODE_ID, COMFYUI_PROMPT_INPUT_KEY, COMFYUI_NEGATIVE_NODE_ID,
# COMFYUI_DEFAULT_NEGATIVE_PROMPT, COMFYUI_MODEL_NAME, COMFYUI_VIDEO_* fields, COMFYUI_VIDEO_MODEL_NAME

# Telegram bot (optional — per-workspace in Studio Settings, or env defaults for single-tenant)
# Telegram does not POST to Directely until you call setWebhook (see INSTALLATION.md §9).
# TELEGRAM_BOT_TOKEN=123456789:AAHxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TELEGRAM_CHAT_ID=551234567
# TELEGRAM_WEBHOOK_SECRET=replace-with-a-long-random-string
# Webhook URL must be HTTPS, e.g. https://YOUR_DOMAIN/v1/integrations/telegram/webhook
# Register once after saving Studio settings (same token + secret in shell):
#   export TELEGRAM_BOT_TOKEN=… TELEGRAM_WEBHOOK_SECRET=…
#   ./scripts/telegram-set-webhook.sh https://YOUR_DOMAIN
# Or: curl -sS -X POST "https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/setWebhook" \
#   --data-urlencode "url=https://YOUR_DOMAIN/v1/integrations/telegram/webhook" \
#   --data-urlencode "secret_token=${TELEGRAM_WEBHOOK_SECRET}"

# Webhook HMAC (generate strong random for production)
# WEBHOOK_SIGNING_SECRET=

# Telegram — failure/stop notifications (inline Retry + Open Studio when PUBLIC URLs are set)
# TELEGRAM_NOTIFY_PIPELINE_FAILURES=true
# DIRECTOR_PUBLIC_APP_URL=https://studio.example.com   # optional; enables ?agentRun= deep links from Telegram
# PUBLIC_API_BASE_URL=https://api.example.com          # optional; OAuth redirect base for YouTube connect

# YouTube Data API (optional — per-workspace in Studio, or env for single-tenant)
# YOUTUBE_CLIENT_ID=
# YOUTUBE_CLIENT_SECRET=
# YOUTUBE_REFRESH_TOKEN=           # normally obtained via Studio “Connect YouTube (OAuth)”
# YOUTUBE_AUTO_UPLOAD_AFTER_EXPORT=false
# YOUTUBE_DEFAULT_PRIVACY=unlisted   # public | unlisted | private
# YOUTUBE_SHARE_WATCH_LINK_IN_TELEGRAM=false
# BURN_SUBTITLES_IN_FINAL_CUT_DEFAULT=false   # agent-run auto final_cut burns subtitles.vtt when present
